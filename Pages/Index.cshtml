@page
@model hhru.Pages.IndexModel

<h1>Hhru — возможности</h1>

@if (!Model.Opportunities.Any())
{
    <div class="card">
        <p>Пока возможностей нет.</p>
    </div>
}
else
{
    foreach (var item in Model.Opportunities)
    {
        <div class="card">
            <h3>@item.Title</h3>
            <p>@item.ShortDescription</p>
            <p><b>Компания:</b> @item.CompanyName</p>
            <p><b>Город:</b> @item.City</p>
            <p><b>Тип:</b> @item.Type</p>
            <p><b>Статус:</b> @item.Status</p>
        </div>
    }
}