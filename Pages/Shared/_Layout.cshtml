<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hhru</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background: #f5f7fb;
            color: #222;
        }

        header {
            background: white;
            border-bottom: 1px solid #ddd;
            padding: 16px 24px;
        }

        nav {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }

            nav a {
                text-decoration: none;
                color: #2563eb;
                font-weight: 600;
            }

        main {
            max-width: 1000px;
            margin: 24px auto;
            padding: 0 16px;
        }

        .card {
            background: white;
            border: 1px solid #ddd;
            border-radius: 10px;
            padding: 16px;
            margin-bottom: 16px;
        }

        .form-group {
            margin-bottom: 12px;
        }

        input, textarea, select {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 8px;
            box-sizing: border-box;
        }

        button {
            background: #2563eb;
            color: white;
            border: none;
            padding: 10px 16px;
            border-radius: 8px;
            cursor: pointer;
        }

        .success {
            color: green;
        }

        .error {
            color: red;
        }
    </style>
</head>
<body>
    <header>
        <nav>
            <a asp-page="/Index">Главная</a>
            <a asp-page="/Login">Вход</a>
            <a asp-page="/Register">Регистрация</a>
            <a asp-page="/ApplicantProfile">Профиль соискателя</a>
            <a asp-page="/EmployerProfile">Профиль работодателя</a>
            <a asp-page="/OpportunityCreate">Создать возможность</a>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>
</body>
</html>